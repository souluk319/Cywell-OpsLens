    "evidence:certification:ci-runner:promote": "node ./scripts/promote-certification-ci-runner-evidence.mjs",
    "verify:community-submission": "node ./scripts/verify-community-operator-submission.mjs",
    "verify:catalog-toolchain": "node ./scripts/verify-catalog-toolchain-plan.mjs",
    "verify:images": "node ./scripts/verify-image-build-readiness.mjs",
    "verify:images:build": "node ./scripts/verify-image-build-readiness.mjs --build",
    "verify:lab-bootstrap": "node ./scripts/verify-lab-bootstrap-plan.mjs",
    "verify:lab-handoff": "node ./scripts/verify-lab-server-handoff.mjs",
    "verify:lab-image-map": "node ./scripts/verify-lab-image-map-preview.mjs",
    "verify:crc-demo-readiness": "node ./scripts/verify-crc-demo-readiness.mjs",
    "verify:dev012-handoff": "node ./scripts/verify-dev012-handoff-readiness.mjs",
    "overnight:checkpoint": "node ./scripts/run-dev012-overnight-checkpoint.mjs --once",
