{
  "name": "kugnus-ops-lens",
  "version": "0.1.0",
  "private": true,
  "description": "Cywell OpsLens MVP 0.1 console-shaped OpenShift operations AI prototype.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @kugnus/contracts build && npm run -w @kugnus/rag build && npm run -w @kugnus/operator-controller build && npm run -w @kugnus/api build && npm run -w @kugnus/web build",
    "dev": "node ./scripts/dev.mjs",
    "dev:api": "npm run -w @kugnus/api dev",
    "dev:web": "npm run -w @kugnus/web dev",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "verify:mvp": "node ./scripts/verify-mvp-gate.mjs",
    "verify:env": "node ./scripts/verify-env-contract.mjs",
    "verify:rag": "npm run -w @kugnus/rag build && node ./scripts/verify-rag-index.mjs",
    "verify:rag:approval-queue": "npm run -w @kugnus/rag build && node ./scripts/verify-rag-approval-queue.mjs",
    "verify:rag:production-readiness": "node ./scripts/verify-rag-production-readiness.mjs",
    "verify:operator": "node ./scripts/verify-operator-package.mjs",
    "verify:operator:package": "node ./scripts/verify-operator-package.mjs",
    "verify:operator:dry-run": "node ./scripts/verify-operator-dry-run.mjs",
    "verify:ocp:target-profile": "node ./scripts/verify-ocp-target-profile.mjs",
