    "verify:install-plan": "node ./scripts/verify-install-approval-plan.mjs",
    "verify:operator:reconcile": "npm run -w @kugnus/operator-controller build && node ./scripts/verify-operator-reconcile.mjs",
    "verify:operator:runtime": "npm run -w @kugnus/operator-controller build && node ./scripts/verify-operator-runtime-parity.mjs",
    "verify:console-plugin": "node ./scripts/verify-console-plugin-assets.mjs",
    "evidence:dev015:screens": "node ./scripts/capture-dev015-demo-evidence.mjs",
    "verify:demo-brief-pages": "node ./scripts/verify-demo-brief-pages.mjs",
    "console-plugin:enable-patch": "node ./scripts/print-console-plugin-enable-patch.mjs",
    "verify:web-shell": "node ./scripts/verify-web-shell-contract.mjs",
