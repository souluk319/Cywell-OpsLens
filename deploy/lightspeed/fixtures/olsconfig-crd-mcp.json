                              "name": {
                                "type": "string"
                              },
                              "valueFrom": {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "enum": [
                                      "secret",
                                      "kubernetes",
                                      "client"
                                    ]
                                  },
                                  "secretRef": {
                                    "type": "object",
                                    "properties": {
                                      "name": {
                                        "type": "string"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ]
