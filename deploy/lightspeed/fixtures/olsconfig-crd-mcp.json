{
  "apiVersion": "apiextensions.k8s.io/v1",
  "kind": "CustomResourceDefinition",
  "metadata": {
    "name": "olsconfigs.ols.openshift.io"
  },
  "spec": {
    "group": "ols.openshift.io",
    "names": {
      "kind": "OLSConfig",
      "plural": "olsconfigs"
    },
    "versions": [
      {
        "name": "v1alpha1",
        "served": true,
        "storage": true,
        "schema": {
          "openAPIV3Schema": {
            "type": "object",
            "properties": {
